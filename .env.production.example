# Production Environment Variables Template
# Copy this file to .env.production and fill in your values
# Then run: ./scripts/sync-env-to-vercel.sh

# ============================================================================
# SUPABASE CONFIGURATION (Required for analytics)
# ============================================================================
# Get these from: https://supabase.com/dashboard > Project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE=your-service-role-key-here

# ============================================================================
# ADMIN CONFIGURATION (Required for admin analytics dashboard)
# ============================================================================
# Comma-separated list of admin email addresses
ADMIN_EMAILS=lvduit08@gmail.com,duyet.cs@gmail.com

# ============================================================================
# AI PROVIDER API KEYS (Optional - users can provide their own)
# ============================================================================
# Only set these if you want to provide free API access to all users
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_GENERATIVE_AI_API_KEY=AI...

# ============================================================================
# SECURITY (Required)
# ============================================================================
# Generate with: openssl rand -base64 32
CSRF_SECRET=your-csrf-secret-here
ENCRYPTION_KEY=your-encryption-key-here

# ============================================================================
# OPTIONAL CONFIGURATION
# ============================================================================
# OLLAMA_BASE_URL=http://localhost:11434
# NEXT_PUBLIC_APP_NAME=Okie
# NEXT_PUBLIC_VERCEL_URL=okie.one
